# The WhatsApp number of the user who will receive the prompts/confirmations.
# It should include the country code and end with @s.whatsapp.net
# Example: 1234567890@s.whatsapp.net (1 is the country code, followed by the 10 digit number)
WHATSAPP_TARGET_NUMBER=1234567890@s.whatsapp.net

# Optional: Comma separated list of individual sender numbers allowed to reply.
# This acts as a security whitelist for who can answer questions when the TARGET_NUMBER is a WhatsApp Group
# WHATSAPP_ALLOWED_NUMBERS=123@s.whatsapp.net,456@s.whatsapp.net
